<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Bubble Shooter · Кампания</title>
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/12.10.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/12.10.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/12.10.0/firebase-firestore-compat.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Comic Sans MS', 'Chalkboard SE', 'Segoe UI', cursive, sans-serif;
        }
        body {
            min-height: 100vh;
            background: radial-gradient(circle at 20% 30%, #ff9a9e, #fad0c4, #fad0c4);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 16px;
            position: relative;
            overflow-x: hidden;
        }
        .bubble {
            position: absolute;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            pointer-events: none;
            bottom: -100px;
            animation: rise 8s infinite ease-in;
        }
        @keyframes rise {
            0% { transform: translateY(0) scale(1); opacity: 0.8; }
            100% { transform: translateY(-120vh) scale(1.5); opacity: 0; }
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(10px);
            border-radius: 50px;
            border: 2px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3), inset 0 0 20px rgba(255, 255, 255, 0.5);
            padding: 30px 25px;
            width: 100%;
            max-width: 500px;
            color: #2c3e50;
            text-shadow: 2px 2px 4px rgba(255, 255, 255, 0.5);
        }
        h1 {
            font-size: 2.5rem;
            text-align: center;
            margin-bottom: 20px;
            background: linear-gradient(45deg, #f093fb, #f5576c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .level-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin: 20px 0;
        }
        .level-item {
            background: rgba(255, 255, 255, 0.3);
            border-radius: 40px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            border: 2px solid rgba(255,255,255,0.5);
            box-shadow: 0 5px 10px rgba(0,0,0,0.1);
        }
        .level-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            padding: 0 5px;
        }
        .level-number {
            font-size: 2rem;
            font-weight: bold;
            color: #2c3e50;
        }
        .stars-container {
            display: flex;
            gap: 8px;
            align-items: center;
        }
        .star {
            font-size: 2.2rem;
            line-height: 1;
        }
        .star.filled {
            color: #FFD700;
            text-shadow: 0 0 10px rgba(255,215,0,0.8);
        }
        .star.empty {
            color: #555;
            text-shadow: none;
        }
        .btn-play, .btn-secret {
            background: linear-gradient(145deg, #f1c40f, #e67e22);
            color: white;
            border: none;
            padding: 12px 0;
            border-radius: 40px;
            font-size: 1.5rem;
            font-weight: bold;
            width: 100%;
            box-shadow: 0 5px 0 #b45d1a;
            cursor: pointer;
            transition: 0.1s;
        }
        .btn-play:active {
            transform: translateY(5px);
            box-shadow: none;
        }
        .btn-secret {
            background: linear-gradient(145deg, #9b59b6, #8e44ad);
            box-shadow: 0 5px 0 #6c3483;
        }
        .btn-secret:active {
            transform: translateY(5px);
            box-shadow: none;
        }
        .btn-secret.disabled {
            opacity: 0.5;
            pointer-events: none;
            filter: grayscale(1);
        }
        .btn.secondary {
            background: linear-gradient(145deg, #34495e, #2c3e50);
            box-shadow: 0 5px 0 #1a252f;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 60px;
            font-size: 1.3rem;
            width: 100%;
            margin-top: 20px;
            cursor: pointer;
        }
        .loading {
            text-align: center;
            font-size: 1.5rem;
            color: white;
            padding: 40px;
        }
        .toast {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0,0,0,0.8);
            color: gold;
            font-size: 0.9rem;
            padding: 8px 12px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            z-index: 1000;
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 2px solid gold;
            max-width: 80%;
            width: auto;
            text-align: center;
            word-wrap: break-word;
            line-height: 1.2;
        }
        .toast.show {
            opacity: 1;
        }
        .toast-star {
            font-size: 1.5rem;
            animation: twinkle 0.5s infinite alternate;
        }
        @keyframes twinkle {
            from { transform: scale(1); text-shadow: 0 0 10px gold; }
            to { transform: scale(1.2); text-shadow: 0 0 20px orange; }
        }
    </style>
</head>
<body>
    <div id="bubbles-container"></div>
    <div class="glass-panel" id="app">
        <div class="loading">Загрузка уровней...</div>
    </div>
    <div id="toast" class="toast">
        <span class="toast-star">✨</span>
        <span id="toastText"></span>
    </div>

    <script>
        // Firebase конфигурация
        const firebaseConfig = {
            apiKey: "AIzaSyAb0WLf9uyTXhs6eGw19i_42gUIZZCbP9c",
            authDomain: "bubble-shooter-game-6169e.firebaseapp.com",
            projectId: "bubble-shooter-game-6169e",
            storageBucket: "bubble-shooter-game-6169e.firebasestorage.app",
            messagingSenderId: "260116679476",
            appId: "1:260116679476:web:bf0b75316ce263d483f361"
        };

        firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
        const db = firebase.firestore();

        let currentUser = null;
        const toast = document.getElementById('toast');
        const toastText = document.getElementById('toastText');

        function showToast(message) {
            toastText.innerText = message;
            toast.classList.add('show');
            setTimeout(() => {
                toast.classList.remove('show');
            }, 5000);
        }

        (function createBubbles() {
            const container = document.getElementById('bubbles-container');
            for (let i = 0; i < 15; i++) {
                const bubble = document.createElement('div');
                bubble.className = 'bubble';
                const size = Math.random() * 100 + 30;
                bubble.style.width = size + 'px';
                bubble.style.height = size + 'px';
                bubble.style.left = Math.random() * 100 + '%';
                bubble.style.animationDelay = Math.random() * 5 + 's';
                bubble.style.animationDuration = Math.random() * 5 + 8 + 's';
                container.appendChild(bubble);
            }
        })();

        const appDiv = document.getElementById('app');

        auth.onAuthStateChanged(async (user) => {
            if (!user) {
                window.location.href = 'index.html';
                return;
            }

            const userRef = db.collection('users').doc(user.uid);
            const doc = await userRef.get();
            if (!doc.exists) {
                const newUser = {
                    name: user.displayName || user.email || 'Гость',
                    settings: { music: true, sound: true },
                    highScore: 0,
                    endlessHighScore: 0,
                    campaignProgress: {},
                    createdAt: firebase.firestore.FieldValue.serverTimestamp()
                };
                await userRef.set(newUser);
                currentUser = { id: user.uid, ...newUser };
            } else {
                currentUser = { id: user.uid, ...doc.data() };
                if (currentUser.endlessHighScore === undefined) {
                    currentUser.endlessHighScore = 0;
                    await userRef.update({ endlessHighScore: 0 });
                }
            }

            renderLevels(currentUser.campaignProgress || {});
        });

        function renderLevels(progress) {
            const totalLevels = 10;
            const levelsHtml = [];

            for (let i = 1; i <= totalLevels; i++) {
                const starsEarned = progress[i] || 0;
                let starsHtml = '';
                for (let s = 1; s <= 5; s++) {
                    const filled = s <= starsEarned;
                    starsHtml += `<span class="star ${filled ? 'filled' : 'empty'}">★</span>`;
                }

                levelsHtml.push(`
                    <div class="level-item">
                        <div class="level-top">
                            <span class="level-number">${i}</span>
                            <div class="stars-container">
                                ${starsHtml}
                            </div>
                        </div>
                        <button class="btn-play" onclick="playLevel(${i})">Играть</button>
                    </div>
                `);
            }

            const allFiveStars = (() => {
                for (let i = 1; i <= totalLevels; i++) {
                    if ((progress[i] || 0) < 5) return false;
                }
                return true;
            })();

            const secretButtonClass = allFiveStars ? 'btn-secret' : 'btn-secret disabled';
            levelsHtml.push(`
                <div class="level-item">
                    <div class="level-top">
                        <span class="level-number" style="color: gold;">✨</span>
                        <div class="stars-container">
                            <span style="font-size:2rem; color:gold;">Секретный уровень</span>
                        </div>
                    </div>
                    <button class="${secretButtonClass}" onclick="showSecretMessage()" ${allFiveStars ? '' : 'disabled'}>Открыть</button>
                </div>
            `);

            appDiv.innerHTML = `
                <h1>📚 Кампания</h1>
                <div class="level-list">
                    ${levelsHtml.join('')}
                </div>
                <button class="btn secondary" id="backBtn">← Назад</button>
            `;

            document.getElementById('backBtn').addEventListener('click', () => {
                window.location.href = 'index.html';
            });
        }

        window.playLevel = (level) => {
            window.location.href = `game.html?mode=campaign&level=${level}`;
        };

        window.showSecretMessage = () => {
            showToast('Спасибо за прохождение тестовой кампании! Если мне не будет лень, то кампания будет дополняться новыми уровнями с новыми механиками. Но пока что это всё, что есть. Если хотите, можете поиграть в бесконечный режим и посоревноваться с другими игроками. С уважением, Никита ✨');
        };
    </script>
</body>
</html>
